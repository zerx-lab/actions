# Maintainer: zerx-lab <https://github.com/zerx-lab>

pkgname=zerx-lab-zed-nightly-bin
pkgver=0.0.0.nightly.placeholder
pkgrel=1
pkgdesc="Zed 编辑器 Nightly 预编译版本（来自 main 分支每日构建）"
arch=('x86_64')
url="https://zed.dev"
license=('GPL-3.0-or-later' 'AGPL-3.0-or-later')
provides=('zed')
conflicts=('zed' 'zed-git' 'zed-preview' 'zed-preview-bin')
depends=(
    'alsa-lib'
    'fontconfig'
    'libgit2'
    'libxcb'
    'libxkbcommon-x11'
    'openssl'
    'sqlite'
    'zlib'
    'libxkbcommon'
    'wayland'
    'vulkan-icd-loader'
)
optdepends=(
    'clang: C/C++ language support'
    'rust: Rust language support'
)
source_x86_64=("zed-nightly-linux-x86_64.tar.gz::https://github.com/zerx-lab/actions/releases/download/zed-nightly-latest/zed-nightly-linux-x86_64.tar.gz")
sha256sums_x86_64=('SKIP')
options=('!strip')

package() {
    # 解压后目录为 zed-nightly.app/（与官方 bundle-linux 结构一致）
    local _appdir="${srcdir}/zed-nightly.app"

    if [ ! -d "$_appdir" ]; then
        echo "错误：找不到解压后的 zed-nightly.app 目录"
        ls "${srcdir}"
        return 1
    fi

    # ── 保持完整 .app 目录结构 ──────────────────────────────────────────────
    # cli（bin/zed）通过 rpath $ORIGIN/../lib 查找共享库，
    # 通过相对路径 ../libexec/zed-editor 调用编辑器主进程，
    # 必须保持整个目录结构完整，不能分散安装。
    local _installdir="${pkgdir}/usr/lib/zed-nightly.app"

    install -dm755 "${_installdir}/bin"
    install -dm755 "${_installdir}/libexec"
    install -dm755 "${_installdir}/lib"

    # cli wrapper：用户直接调用的入口
    install -Dm755 "${_appdir}/bin/zed" "${_installdir}/bin/zed"

    # 真正的编辑器二进制
    install -Dm755 "${_appdir}/libexec/zed-editor" "${_installdir}/libexec/zed-editor"

    # 运行时共享库（由 rpath $ORIGIN/../lib 加载）
    if [ -d "${_appdir}/lib" ] && [ -n "$(ls -A "${_appdir}/lib" 2>/dev/null)" ]; then
        cp -a "${_appdir}/lib/." "${_installdir}/lib/"
    fi

    # ── /usr/bin/zed 软链到 cli wrapper ────────────────────────────────────
    install -dm755 "${pkgdir}/usr/bin"
    ln -sf "/usr/lib/zed-nightly.app/bin/zed" "${pkgdir}/usr/bin/zed"

    # ── 图标（hicolor 主题规范）────────────────────────────────────────────
    if [ -f "${_appdir}/share/icons/hicolor/512x512/apps/zed.png" ]; then
        install -Dm644 "${_appdir}/share/icons/hicolor/512x512/apps/zed.png" \
            "${pkgdir}/usr/share/icons/hicolor/512x512/apps/zed.png"
    fi
    if [ -f "${_appdir}/share/icons/hicolor/1024x1024/apps/zed.png" ]; then
        install -Dm644 "${_appdir}/share/icons/hicolor/1024x1024/apps/zed.png" \
            "${pkgdir}/usr/share/icons/hicolor/1024x1024/apps/zed.png"
    fi

    # ── desktop 文件（对齐官方 install.sh 的 sed 替换逻辑）──────────────
    # install.sh 安装后会执行：
    #   sed -i "s|Icon=zed|Icon=~/.local/zed-nightly.app/share/icons/.../zed.png|g"
    #   sed -i "s|Exec=zed|Exec=~/.local/zed-nightly.app/bin/zed|g"
    # 系统级安装对应路径前缀改为 /usr/lib/zed-nightly.app/
    local _desktop_src="${_appdir}/share/applications/dev.zed.Zed-Nightly.desktop"
    local _desktop_dst="${pkgdir}/usr/share/applications/dev.zed.Zed-Nightly.desktop"
    local _app_prefix="/usr/lib/zed-nightly.app"

    if [ -f "${_desktop_src}" ]; then
        install -Dm644 "${_desktop_src}" "${_desktop_dst}"

        # Icon：系统级安装图标已在 /usr/share/icons/hicolor/ 标准路径下，
        # 保持 Icon=zed 让桌面环境通过 hicolor 主题查找，不做替换。
        # （install.sh 改为绝对路径是因为它将整个 .app 解压到 ~/.local/，
        #   share/icons/ 在 .app 内存在；系统级安装该路径并不存在）

        # Exec：改为 cli 的绝对路径（与 install.sh 一致）
        sed -i "s|Exec=zed |Exec=${_app_prefix}/bin/zed |g" \
            "${_desktop_dst}"
        sed -i "s|Exec=zed$|Exec=${_app_prefix}/bin/zed|g" \
            "${_desktop_dst}"

        # TryExec：同样改为绝对路径，避免依赖 PATH
        sed -i "s|TryExec=zed|TryExec=${_app_prefix}/bin/zed|g" \
            "${_desktop_dst}"
    fi
}
