# Maintainer: zero <zero@localhost>
# Automatically updated by GitHub Actions

pkgname=clash-party-bin
pkgver=1.9.2
pkgrel=1
pkgdesc="Clash Party - 基于 Mihomo 的代理工具客户端（GUI）"
arch=('x86_64')
url="https://github.com/mihomo-party-org/clash-party"
license=('GPL-3.0-only')
depends=(
    'alsa-lib'
    'at-spi2-core'
    'cairo'
    'dbus'
    'libcups'
    'libdrm'
    'libsecret'
    'libxcomposite'
    'libxdamage'
    'libxext'
    'libxfixes'
    'libxkbcommon'
    'libxrandr'
    'mesa'
    'nss'
    'pango'
    'xdg-utils'
)
optdepends=(
    'libappindicator-gtk3: 系统托盘图标支持'
    'libayatana-appindicator: 系统托盘图标支持（Ayatana）'
)
provides=('clash-party')
conflicts=('clash-party')
options=('!strip')

source_x86_64=("clash-party-${pkgver}.deb::https://github.com/mihomo-party-org/clash-party/releases/download/v${pkgver}/clash-party-linux-${pkgver}-amd64.deb")
sha256sums_x86_64=('SKIP')

package() {
    cd "$srcdir"

    # 解压 .deb 文件
    ar x "clash-party-${pkgver}.deb"

    # 将 data.tar.xz / data.tar.gz 解压到 $pkgdir
    if [ -f data.tar.xz ]; then
        bsdtar -xf data.tar.xz -C "$pkgdir"
    elif [ -f data.tar.gz ]; then
        bsdtar -xf data.tar.gz -C "$pkgdir"
    elif [ -f data.tar.zst ]; then
        bsdtar -xf data.tar.zst -C "$pkgdir"
    else
        echo "::error::未找到 data.tar.*"
        exit 1
    fi

    # 创建 /usr/bin/clash-party 符号链接
    install -d "$pkgdir/usr/bin"
    ln -sf '/opt/clash-party/clash-party' "$pkgdir/usr/bin/clash-party"
}
